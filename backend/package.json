{
  "name": "@apptly/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Apptly sync API: Cloudflare Worker (Hono) verifying Clerk tokens, storing per-user data in D1 + R2.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "test": "vitest run"
  },
  "dependencies": {
    "@apptly/shared": "workspace:*",
    "@clerk/backend": "^1.21.6",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.12.23",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@cloudflare/workers-types": "^4.20250906.0",
    "drizzle-kit": "^0.30.6",
    "wrangler": "^4.35.0"
  }
}
