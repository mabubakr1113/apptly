{
  "name": "@apptly/extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Apptly browser extension (Manifest V3, cross-browser via WXT).",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "typecheck": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@apptly/shared": "workspace:*",
    "@clerk/chrome-extension": "^3.1.32",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@webext-core/fake-browser": "^1.3.1",
    "@wxt-dev/module-react": "^1.1.3",
    "wxt": "^0.19.13"
  }
}
