# Clerk publishable key (client-side; safe to expose, it ships in the bundle).
# Get it from the Clerk Dashboard -> API Keys. Required for the extension to
# load authentication. Copy this file to `.env` and fill the value.
# Full setup: docs/clerk-setup.md
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the Apptly sync API (the Cloudflare Worker). Used by the extension
# to push/pull profile and tracker data. Local dev default below; in production
# set this to your deployed Worker origin (and add that origin to wxt.config.ts
# host_permissions + the CSP connect-src directive).
VITE_API_BASE_URL=http://localhost:8787
