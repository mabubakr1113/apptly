# Clerk publishable key (client-side; safe to expose, it ships in the bundle).
# Use the SAME Clerk application as the extension so accounts/sessions are shared
# and a sign-in on either surface works across both. Clerk Dashboard -> API Keys.
# Full setup: docs/clerk-setup.md
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Clerk secret key (server-side only; NEVER ship to the client). Used by
# clerkMiddleware / server helpers. Clerk Dashboard -> API Keys.
CLERK_SECRET_KEY=sk_test_your_key_here

# Base URL (origin) of the Apptly sync API (the Cloudflare Worker). The web app
# attaches the Clerk session token and calls `${NEXT_PUBLIC_API_BASE_URL}/v1/...`.
# Local dev default below; in production set this to your deployed Worker origin.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# Clerk routing (keeps the in-app <SignIn/> / <SignUp/> pages wired correctly).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
